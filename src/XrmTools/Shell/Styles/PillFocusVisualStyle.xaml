<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:cvrts="clr-namespace:XrmTools.Shell.Converters"
                    xmlns:styles="clr-namespace:XrmTools.Shell.Styles">
    <Style x:Key="PillFocusVisualStyle">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border BorderBrush="{DynamicResource {x:Static styles:ShellColors.FocusStrokeOuterBrushKey}}"
                  BorderThickness="{x:Static styles:StrokeWidths.Thick}"
                  Margin="{x:Static styles:Spacings.XSNudgeInvert}" SnapsToDevicePixels="True"
                  UseLayoutRounding="True"
                  CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={x:Static cvrts:Converters.MultiplyConverter}, ConverterParameter=0.5}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>