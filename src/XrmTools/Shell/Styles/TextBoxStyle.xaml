<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ctrls="clr-namespace:XrmTools.Shell.Controls"
                    xmlns:cvrts="clr-namespace:XrmTools.Shell.Converters"
                    xmlns:styles="clr-namespace:XrmTools.Shell.Styles">
	<Style BasedOn="{StaticResource {x:Type TextBoxBase}}" TargetType="{x:Type ctrls:TextBox}">
		<Setter Property="UIElement.AllowDrop" Value="True"/>
		<Setter Property="AutomationProperties.HelpText"
				Value="{Binding HintText, RelativeSource={RelativeSource Self}, TargetNullValue=''}"/>
		<Setter Property="Control.Background"
				Value="{DynamicResource {x:Static styles:ShellColors.ControlFillDefaultBrushKey}}"/>
		<Setter Property="Control.BorderBrush"
				Value="{DynamicResource {x:Static styles:ShellColors.ControlStrokeDefaultBrushKey}}"/>
		<Setter Property="Control.BorderThickness" Value="{x:Static styles:StrokeWidths.Thin}"/>
		<Setter Property="TextBoxBase.CaretBrush"
				Value="{Binding Foreground, RelativeSource={RelativeSource Self}}"/>
		<Setter Property="ctrls:TextBox.CornerRadius" Value="{x:Static styles:CornerRadii.M}"/>
		<Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}"/>
		<Setter Property="Control.Foreground"
				Value="{DynamicResource {x:Static styles:ShellColors.TextFillPrimaryBrushKey}}"/>
		<Setter Property="TextBoxBase.HorizontalScrollBarVisibility" Value="Hidden"/>
		<Setter Property="FrameworkElement.MinHeight" Value="{x:Static styles:Sizes.ControlMinHeight}"/>
		<Setter Property="FrameworkElement.MinWidth" Value="{x:Static styles:Sizes.ControlMinWidth}"/>
		<Setter Property="Control.Padding" Value="{x:Static styles:Spacings.XS}"/>
		<Setter Property="TextBoxBase.SelectionBrush"
				Value="{DynamicResource {x:Static styles:ShellColors.AccentFillSelectedTextBackgroundBrushKey}}"/>
		<Setter Property="UIElement.SnapsToDevicePixels" Value="True"/>
		<Setter Property="ToolTipService.VerticalOffset" Value="{x:Static ctrls:TextBox.ToolTipOffset}"/>
		<Setter Property="FrameworkElement.UseLayoutRounding" Value="True"/>
		<Setter Property="TextBoxBase.VerticalScrollBarVisibility" Value="Auto"/>
		<Setter Property="Control.Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type ctrls:TextBox}">
					<Grid>
						<UIElement.Clip>
							<MultiBinding Converter="{x:Static cvrts:Converters.ClipConverter}">
								<Binding Path="ActualWidth" RelativeSource="{RelativeSource Self}"/>
								<Binding Path="ActualHeight" RelativeSource="{RelativeSource Self}"/>
								<Binding Path="CornerRadius" RelativeSource="{RelativeSource TemplatedParent}"/>
							</MultiBinding>
						</UIElement.Clip>
						<Grid.RowDefinitions>
							<RowDefinition Height="*"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>
						<Border Grid.Row="0" Grid.RowSpan="2" Background="{TemplateBinding Control.Background}"
								BorderBrush="{TemplateBinding Control.BorderBrush}"
								BorderThickness="{TemplateBinding Control.BorderThickness}"
								CornerRadius="{TemplateBinding ctrls:TextBox.CornerRadius}">
							<Grid Margin="{x:Static styles:Spacings.VerticalXXXSInvert}">
								<ctrls:ScrollViewer x:Name="PART_ContentHost"
													HorizontalScrollBarVisibility="{TemplateBinding TextBoxBase.HorizontalScrollBarVisibility}"
													MinHeight="{x:Static styles:Sizes.ControlMinHeight}" Padding="{TemplateBinding Control.Padding}"
													VerticalScrollBarVisibility="{TemplateBinding TextBoxBase.VerticalScrollBarVisibility}"/>
								<Border Padding="{x:Static styles:Spacings.HorizontalXXS}">
									<TextBlock x:Name="HintText"
											   Foreground="{DynamicResource {x:Static styles:ShellColors.TextFillSecondaryBrushKey}}"
											   HorizontalAlignment="Left" IsHitTestVisible="False" Margin="{TemplateBinding Control.Padding}"
											   Text="{TemplateBinding ctrls:TextBox.HintText}" TextTrimming="CharacterEllipsis"
											   TextWrapping="NoWrap" VerticalAlignment="Top" Visibility="Collapsed"/>
								</Border>
							</Grid>
						</Border>
						<Rectangle x:Name="TypingIndicator" Grid.Row="1" Height="{x:Static ctrls:TextBox.TypingIndicatorHeightRest}"
								   IsHitTestVisible="False" Fill="{TemplateBinding Control.BorderBrush}" Stretch="Fill"
								   VerticalAlignment="Bottom"/>
					</Grid>
					<ControlTemplate.Triggers>
						<Trigger Property="UIElement.IsEnabled" Value="False">
							<Setter TargetName="HintText"
									Value="{DynamicResource {x:Static styles:ShellColors.TextFillDisabledBrushKey}}"
									Property="TextBlock.Foreground"/>
						</Trigger>
						<Trigger Property="UIElement.IsKeyboardFocusWithin" Value="True">
							<Setter TargetName="TypingIndicator"
									Value="{DynamicResource {x:Static styles:ShellColors.AccentFillDefaultBrushKey}}"
									Property="Shape.Fill"/>
							<Setter TargetName="TypingIndicator" Value="{x:Static ctrls:TextBox.TypingIndicatorHeightTyping}"
									Property="FrameworkElement.Height"/>
						</Trigger>
						<Trigger Value="{x:Null}" Property="TextBox.Text">
							<Setter TargetName="HintText" Property="UIElement.Visibility" Value="Visible"/>
						</Trigger>
						<Trigger Property="TextBox.Text" Value="">
							<Setter TargetName="HintText" Property="UIElement.Visibility" Value="Visible"/>
						</Trigger>
						<Trigger Property="Validation.HasError" Value="True">
							<Setter TargetName="TypingIndicator" Property="UIElement.Visibility" Value="Hidden"/>
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
		<Setter Property="Validation.ErrorTemplate">
			<Setter.Value>
				<ControlTemplate/>
			</Setter.Value>
		</Setter>
		<Style.Triggers>
			<Trigger Property="UIElement.IsEnabled" Value="False">
				<Setter Property="Control.Foreground"
						Value="{DynamicResource {x:Static styles:ShellColors.TextFillDisabledBrushKey}}"/>
			</Trigger>
			<Trigger Property="UIElement.IsMouseOver" Value="True">
				<Setter Property="Control.Background"
						Value="{DynamicResource {x:Static styles:ShellColors.ControlFillSecondaryBrushKey}}"/>
			</Trigger>
			<Trigger Property="UIElement.IsKeyboardFocusWithin" Value="True">
				<Setter Property="Control.Background"
						Value="{DynamicResource {x:Static styles:ShellColors.ControlFillActiveInputBrushKey}}"/>
			</Trigger>
			<Trigger Property="UIElement.IsKeyboardFocusWithin" Value="False">
				<Setter Property="TextBoxBase.CaretBrush"
						Value="{DynamicResource {x:Static styles:ShellColors.ControlFillTransparentBrushKey}}"/>
			</Trigger>
			<Trigger Property="Validation.HasError" Value="True">
				<Setter Property="Control.BorderBrush"
						Value="{DynamicResource {x:Static styles:ShellColors.SystemFillCriticalBrushKey}}"/>
			</Trigger>
			<DataTrigger Binding="{Binding MinLines, RelativeSource={RelativeSource Self}, Converter={x:Static cvrts:Converters.IsGreaterThanConverter}, ConverterParameter=1}"
						 Value="True">
				<Setter Property="TextBoxBase.AcceptsReturn" Value="True"/>
				<Setter Property="TextBox.MaxLines" Value="{Binding MinLines, RelativeSource={RelativeSource Self}}"/>
				<Setter Property="TextBox.TextWrapping" Value="Wrap"/>
			</DataTrigger>
		</Style.Triggers>
	</Style>
</ResourceDictionary>