<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ctrls="clr-namespace:XrmTools.Shell.Controls"
                    xmlns:styles="clr-namespace:XrmTools.Shell.Styles">
    <Style TargetType="{x:Type ctrls:TextBlock}">
        <Setter Property="TextBlock.LineHeight" Value="{x:Static styles:Sizes.ContentMinHeight}"/>
        <Style.Triggers>
            <Trigger Property="UIElement.IsEnabled" Value="False">
                <Setter Property="TextBlock.Foreground"
                Value="{DynamicResource {x:Static styles:ShellColors.TextFillDisabledBrushKey}}"/>
            </Trigger>
            <Trigger Property="ctrls:TextBlock.Kind" Value="Body">
                <Setter Property="TextBlock.FontSize"
                Value="{Binding BodyFontSize, Source={x:Static styles:Typography.Instance}}"/>
                <Setter Property="TextBlock.FontWeight" Value="Normal"/>
                <Setter Property="TextBlock.LineHeight" Value="{x:Static styles:Typography.BodyLineHeight}"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            </Trigger>
            <Trigger Property="ctrls:TextBlock.Kind" Value="BodyLarge">
                <Setter Property="TextBlock.FontSize"
                Value="{Binding BodyLargeFontSize, Source={x:Static styles:Typography.Instance}}"/>
                <Setter Property="TextBlock.FontWeight" Value="Normal"/>
                <Setter Property="TextBlock.LineHeight" Value="{x:Static styles:Typography.BodyLargeLineHeight}"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            </Trigger>
            <Trigger Property="ctrls:TextBlock.Kind" Value="BodyLargeStrong">
                <Setter Property="TextBlock.FontSize"
                Value="{Binding BodyLargeFontSize, Source={x:Static styles:Typography.Instance}}"/>
                <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                <Setter Property="TextBlock.LineHeight" Value="{x:Static styles:Typography.BodyLargeLineHeight}"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            </Trigger>
            <Trigger Property="ctrls:TextBlock.Kind" Value="BodyStrong">
                <Setter Property="TextBlock.FontSize"
                Value="{Binding BodyFontSize, Source={x:Static styles:Typography.Instance}}"/>
                <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                <Setter Property="TextBlock.LineHeight" Value="{x:Static styles:Typography.BodyLineHeight}"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            </Trigger>
            <Trigger Property="ctrls:TextBlock.Kind" Value="Caption">
                <Setter Property="TextBlock.FontSize"
                Value="{Binding CaptionFontSize, Source={x:Static styles:Typography.Instance}}"/>
                <Setter Property="TextBlock.FontWeight" Value="Normal"/>
                <Setter Property="TextBlock.LineHeight" Value="{x:Static styles:Typography.CaptionLineHeight}"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            </Trigger>
            <Trigger Property="ctrls:TextBlock.Kind" Value="Code">
                <Setter Property="TextBlock.FontFamily"
                Value="{Binding CodeFontFamily, Source={x:Static styles:Typography.Instance}}"/>
                <Setter Property="TextBlock.FontSize"
                Value="{Binding CodeFontSize, Source={x:Static styles:Typography.Instance}}"/>
                <Setter Property="TextBlock.FontWeight" Value="Normal"/>
                <Setter Property="TextBlock.LineHeight" Value="{x:Static styles:Typography.CodeLineHeight}"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            </Trigger>
            <Trigger Property="ctrls:TextBlock.Kind" Value="Display">
                <Setter Property="TextBlock.FontSize"
                Value="{Binding DisplayFontSize, Source={x:Static styles:Typography.Instance}}"/>
                <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                <Setter Property="TextBlock.LineHeight" Value="{x:Static styles:Typography.DisplayLineHeight}"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            </Trigger>
            <Trigger Property="ctrls:TextBlock.Kind" Value="Subtitle">
                <Setter Property="TextBlock.FontSize"
                Value="{Binding SubtitleFontSize, Source={x:Static styles:Typography.Instance}}"/>
                <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                <Setter Property="TextBlock.LineHeight" Value="{x:Static styles:Typography.SubtitleLineHeight}"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            </Trigger>
            <Trigger Property="ctrls:TextBlock.Kind" Value="Title">
                <Setter Property="TextBlock.FontSize"
                Value="{Binding TitleFontSize, Source={x:Static styles:Typography.Instance}}"/>
                <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                <Setter Property="TextBlock.LineHeight" Value="{x:Static styles:Typography.TitleLineHeight}"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            </Trigger>
            <Trigger Property="ctrls:TextBlock.Kind" Value="TitleLarge">
                <Setter Property="TextBlock.FontSize"
                Value="{Binding TitleLargeFontSize, Source={x:Static styles:Typography.Instance}}"/>
                <Setter Property="TextBlock.FontWeight" Value="SemiBold"/>
                <Setter Property="TextBlock.LineHeight" Value="{x:Static styles:Typography.TitleLargeLineHeight}"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            </Trigger>
            <Trigger Property="ctrls:TextBlock.PreferredTextFormattingMode" Value="Display">
                <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            </Trigger>
            <Trigger Property="ctrls:TextBlock.PreferredTextFormattingMode" Value="Ideal">
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>