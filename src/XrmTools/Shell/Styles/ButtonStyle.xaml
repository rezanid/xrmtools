<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ctrls="clr-namespace:XrmTools.Shell.Controls"
                    xmlns:cvrts="clr-namespace:XrmTools.Shell.Converters"
                    xmlns:img="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
                    xmlns:imgbg="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Imaging"
                    xmlns:styles="clr-namespace:XrmTools.Shell.Styles">
    <Style BasedOn="{x:Static styles:ShellStyles.ButtonBase}" TargetType="{x:Type ctrls:Button}">
        <Setter Property="ctrls:Button.CornerRadius" Value="{x:Static styles:CornerRadii.M}"/>
        <Setter Property="Control.Padding" Value="{x:Static styles:Spacings.HorizontalS}"/>
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ctrls:Button}">
                    <Border Background="{TemplateBinding Control.Background}"
                  BorderBrush="{TemplateBinding Control.BorderBrush}"
                  BorderThickness="{TemplateBinding Control.BorderThickness}"
                  CornerRadius="{TemplateBinding ctrls:Button.CornerRadius}"
                  Padding="{TemplateBinding Control.Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                              MinHeight="{x:Static styles:Sizes.ContentMinHeight}" RecognizesAccessKey="True"
                              VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="ctrls:Button.Kind" Value="Accent">
                <Setter Property="Control.Background"
                Value="{DynamicResource {x:Static styles:ShellColors.AccentFillDefaultBrushKey}}"/>
                <Setter Property="Control.BorderBrush"
                Value="{DynamicResource {x:Static styles:ShellColors.AccentFillDefaultBrushKey}}"/>
                <Setter Property="Control.Foreground"
                Value="{DynamicResource {x:Static styles:ShellColors.TextOnAccentFillPrimaryBrushKey}}"/>
                <Setter Property="imgbg:ImageThemingUtilities.ImageBackgroundColor"
                Value="{DynamicResource {x:Static styles:ShellColors.AccentFillDefaultColorKey}}"/>
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="ctrls:Button.Kind" Value="Accent"/>
                    <Condition Property="UIElement.IsEnabled" Value="False"/>
                </MultiTrigger.Conditions>
                <Setter Property="Control.Background"
                Value="{DynamicResource {x:Static styles:ShellColors.AccentFillDisabledBrushKey}}"/>
                <Setter Property="Control.BorderBrush"
                Value="{DynamicResource {x:Static styles:ShellColors.AccentFillDisabledBrushKey}}"/>
                <Setter Property="Control.Foreground"
                Value="{DynamicResource {x:Static styles:ShellColors.TextOnAccentFillDisabledBrushKey}}"/>
                <Setter Property="img:CrispImage.GrayscaleBiasColor"
                Value="{DynamicResource {x:Static styles:ShellColors.TextOnAccentFillDisabledColorKey}}"/>
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="ctrls:Button.Kind" Value="Accent"/>
                    <Condition Property="UIElement.IsMouseOver" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter Property="Control.Background"
                Value="{DynamicResource {x:Static styles:ShellColors.AccentFillSecondaryBrushKey}}"/>
                <Setter Property="Control.BorderBrush"
                Value="{DynamicResource {x:Static styles:ShellColors.AccentFillSecondaryBrushKey}}"/>
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="ctrls:Button.Kind" Value="Accent"/>
                    <Condition Property="ButtonBase.IsPressed" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter Property="Control.Background"
                Value="{DynamicResource {x:Static styles:ShellColors.AccentFillTertiaryBrushKey}}"/>
                <Setter Property="Control.BorderBrush"
                Value="{DynamicResource {x:Static styles:ShellColors.AccentFillTertiaryBrushKey}}"/>
                <Setter Property="Control.Foreground"
                Value="{DynamicResource {x:Static styles:ShellColors.TextOnAccentFillSecondaryBrushKey}}"/>
            </MultiTrigger>
            <Trigger Property="ctrls:Button.Kind" Value="Pill">
                <Setter Property="ctrls:Button.CornerRadius"
                Value="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={x:Static cvrts:Converters.MultiplyConverter}, ConverterParameter=0.5}"/>
                <Setter Property="FrameworkElement.FocusVisualStyle"
                Value="{x:Static styles:ShellInternalStyles.PillFocusVisual}"/>
            </Trigger>
            <Trigger Property="ctrls:Button.Kind" Value="Subtle">
                <Setter Property="Control.Background"
                Value="{DynamicResource {x:Static styles:ShellColors.ControlFillTransparentBrushKey}}"/>
                <Setter Property="Control.BorderBrush"
                Value="{DynamicResource {x:Static styles:ShellColors.ControlStrokeTransparentBrushKey}}"/>
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="ctrls:Button.Kind" Value="Subtle"/>
                    <Condition Property="UIElement.IsMouseOver" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter Property="Control.Background"
                Value="{DynamicResource {x:Static styles:ShellColors.SubtleFillSecondaryBrushKey}}"/>
                <Setter Property="Control.BorderBrush"
                Value="{DynamicResource {x:Static styles:ShellColors.ControlStrokeSecondaryBrushKey}}"/>
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="ctrls:Button.Kind" Value="Subtle"/>
                    <Condition Property="ButtonBase.IsPressed" Value="True"/>
                </MultiTrigger.Conditions>
                <Setter Property="Control.Background"
                Value="{DynamicResource {x:Static styles:ShellColors.SubtleFillTertiaryBrushKey}}"/>
                <Setter Property="Control.BorderBrush"
                Value="{DynamicResource {x:Static styles:ShellColors.SubtleFillTertiaryBrushKey}}"/>
                <Setter Property="Control.Foreground"
                Value="{DynamicResource {x:Static styles:ShellColors.TextFillSecondaryBrushKey}}"/>
            </MultiTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>